# ─── Cortex Figma Agent ────────────────────────────────────────────────────
# Copie este arquivo para .env e preencha os valores em branco.
# NUNCA commite o arquivo .env.
#
# Escopos obrigatórios no token do Figma:
#   file_content:write · files:write · file_comments:write
# Gere em: figma.com → Settings → Security → Personal access tokens

FIGMA_ACCESS_TOKEN=

# ─── Time e design system (não altere) ─────────────────────────────────────

FIGMA_TEAM_ID=949730096562549618

# Arquivos de referência — somente leitura, nunca edite no Figma
FIGMA_DSR_FILE_ID=FmEflw5VxrJNKaQ0SR62Kz
FIGMA_ICONS_FILE_ID=JkbKb6Qbz2iraZQ5gcGxmi
FIGMA_IDENTITY_FILE_ID=ZFiNk45C8FP7OY53jjElEL

# ─── IDs dos projetos por oferta (não altere) ───────────────────────────────

FIGMA_GEO_PROJECT_ID=284089424
FIGMA_GRO_PROJECT_ID=43838342
FIGMA_BRA_PROJECT_ID=61425821
FIGMA_REA_PROJECT_ID=255743376
FIGMA_OUT_PROJECT_ID=43713678

# ─── Arquivos de trabalho (preencha após criar cada arquivo no Figma) ───────
# Crie cada arquivo no projeto correspondente e cole o file ID da URL.
# Você não precisa criar todos — preencha apenas os que for usar.
#
# Como encontrar o file ID:
#   figma.com/design/<FILE_ID>/nome-do-arquivo

FIGMA_GEO_WORKING_FILE_ID=   # [GEO] Screen Builder — Rascunhos
FIGMA_GRO_WORKING_FILE_ID=   # [GRO] Screen Builder — Rascunhos
FIGMA_BRA_WORKING_FILE_ID=   # [BRA] Screen Builder — Rascunhos
FIGMA_REA_WORKING_FILE_ID=   # [REA] Screen Builder — Rascunhos
FIGMA_OUT_WORKING_FILE_ID=   # [OUT] Screen Builder — Rascunhos
